{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "TenderTracker.API": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=tendertracker;Username=postgres;Password=postgres"
  },
  "GosPlanApi": {
    "BaseUrl": "https://v2.gosplan.info",
    "RequestDelayMs": 1000,
    "MaxRetries": 3,
    "TimeoutSeconds": 30
  },
  "BackgroundService": {
    "SearchIntervalMinutes": 30,
    "InitialDelaySeconds": 10
  },
  "ExportSettings": {
    "PdfTemplatePath": "Templates/pdf-template.html",
    "DocxTemplatePath": "Templates/docx-template.xml",
    "CacheDurationHours": 24,
    "ExportDirectory": "Exports/Documents"
  },
  "DocumentSyncSettings": {
    "EnableAutoSync": true,
    "DownloadAfterSearch": true,
    "SyncIntervalHours": 2,
    "SyncOnlyCompatibleTenders": true,
    "MinMatchScore": 60,
    "ResyncExistingDocuments": false,
    "MaxTendersPerSync": 10,
    "DownloadNotification": true,
    "DownloadAllDocuments": false,
    "DocumentTypesToDownload": [],
    "ApiDelaySeconds": 2,
    "MaxRetryCount": 3,
    "RetryDelayMinutes": 5
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "EnableSsl": true
  },
  "Telegram": {
    "BotToken": ""
  }
}
